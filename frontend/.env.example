# ──────────────────────────────────────────────────────────────────────
# WhatIsMyTip frontend env vars (template).
#
# Loaded at build time by Nuxt.  Any var without a NUXT_PUBLIC_ prefix
# is server-side only and will NOT be exposed to the browser.
#
# Copy to .env for local dev:
#   cp .env.example .env
#
# In production these are configured on the App Platform static_site
# component (BUILD_TIME scope), not via this file.
#
# ── Mapping to nuxt.config.ts runtimeConfig.public ──────────────────
#   NUXT_PUBLIC_API_BASE          -> runtimeConfig.public.apiBase
#   NUXT_PUBLIC_UMAMI_HOST        -> runtimeConfig.public.umamiHost
#   NUXT_PUBLIC_UMAMI_WEBSITE_ID  -> runtimeConfig.public.umamiWebsiteId
#   NUXT_PUBLIC_SITE_URL          -> runtimeConfig.public.siteUrl
#   NUXT_PUBLIC_BUY_ME_A_COFFEE_URL -> runtimeConfig.public.buyMeACoffeeUrl
# All client-visible vars use the NUXT_PUBLIC_* prefix so Nuxt exposes
# them to the browser via the public runtime config.  Fix CR-002/003.
# ──────────────────────────────────────────────────────────────────────

# ── Backend API base ────────────────────────────────────────────────
# The single base URL of the FastAPI backend.
#   Local dev: http://localhost:8000
#   Production: https://whatismytip.com (the nginx proxy fronts the
#   FastAPI service at the public domain)
NUXT_PUBLIC_API_BASE=http://localhost:8000

# ── Analytics (Umami) ───────────────────────────────────────────────
# Leave blank to disable analytics in the build.
NUXT_PUBLIC_UMAMI_HOST=
NUXT_PUBLIC_UMAMI_WEBSITE_ID=

# ── Misc ────────────────────────────────────────────────────────────
NUXT_PUBLIC_SITE_URL=https://whatismytip.com
NUXT_PUBLIC_BUY_ME_A_COFFEE_URL=

# ── Build environment (server-side, not exposed to browser) ─────────
NODE_ENV=development
