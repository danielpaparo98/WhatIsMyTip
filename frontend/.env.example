# Frontend env vars (loaded at build time by Nuxt).
#
# Phase 4: the FaaS era is over.  The frontend talks to a single
# FastAPI base URL — no per-function URLs.  The useApi composable
# already falls back to `${apiBase}${path}` when no FaaS URLs are
# set, so a single API base is all you need.

# Base URL of the FastAPI backend.  Defaults to http://localhost:8000
# for local dev.  In production, set this to the public URL of the
# App Platform backend component (e.g. https://api.whatismytip.com
# — or, with the nginx proxy in front, just the public domain).
NUXT_PUBLIC_API_BASE=http://localhost:8000

# ── Analytics (Umami) ──────────────────────────────────────────────────
# Leave blank to disable analytics in the build.
NUXT_PUBLIC_UMAMI_HOST=
NUXT_PUBLIC_UMAMI_WEBSITE_ID=

# ── Misc ───────────────────────────────────────────────────────────────
NUXT_PUBLIC_SITE_URL=https://whatismytip.com
NUXT_PUBLIC_BUY_ME_A_COFFEE_URL=
