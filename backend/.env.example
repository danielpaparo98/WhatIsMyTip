# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
# Database (PostgreSQL via asyncpg).  Append ?ssl=require for managed DBs.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/whatismytip
# Redis.  Use rediss:// for managed Redis (TLS).
REDIS_URL=redis://localhost:6379/0

# Application environment: development | production
ENVIRONMENT=development

# Admin API key.  Required for /api/admin/* endpoints (sent as X-API-Key).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=

# CORS — comma-separated list of allowed origins.  Empty in dev defaults to
# http://localhost:3000 + http://127.0.0.1:3000 (see packages/shared/config.py).
CORS_ORIGINS=

# ---------------------------------------------------------------------------
# Rate limiting (slowapi — Redis-backed in production)
# ---------------------------------------------------------------------------
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# Max accepted request body (bytes).  Defaults to 5 MiB.
MAX_REQUEST_BODY_BYTES=5242880

# ---------------------------------------------------------------------------
# External APIs
# ---------------------------------------------------------------------------
SQUIGGLE_API_BASE=https://api.squiggle.com.au
SQUIGGLE_CONTACT_EMAIL=contact@whatismytip.com

OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---------------------------------------------------------------------------
# Cron / scheduled jobs (in-process APScheduler)
# ---------------------------------------------------------------------------
# Master switch — set to false to silence all cron jobs (useful for local dev).
CRON_ENABLED=true
# IANA timezone used to interpret the cron expressions below.
CRON_TIMEZONE=Australia/Perth

# Cron expressions (5-field).  Defaults match the production schedule.
DAILY_SYNC_CRON=*/15 * * * *
MATCH_COMPLETION_CRON=5,20,35,50 * * * *
TIP_GENERATION_CRON=0 3 * * *
HISTORIC_REFRESH_CRON=0 4 * * 0

# Default season for daily-sync (auto-detected from current year if unset).
CURRENT_SEASON=

# Seasons covered by the historic-refresh job (e.g. "2010-2025").
HISTORIC_REFRESH_SEASONS=2010-2025

# Advisory-lock expiry for in-process jobs.  15 min is the FaaS-era ceiling
# retained as a safety cap.
JOB_LOCK_EXPIRE_SECONDS=900

# ---------------------------------------------------------------------------
# Alerting
# ---------------------------------------------------------------------------
# Master switch.  When true, the AlertingService POSTs to ALERT_WEBHOOK_URL
# for job failures / repeated timeouts.
ALERT_ENABLED=false
ALERT_WEBHOOK_URL=
# Webhook HTTP timeout (seconds).
ALERT_TIMEOUT_SECONDS=10

# ---------------------------------------------------------------------------
# Metrics / observability
# ---------------------------------------------------------------------------
# How long to keep per-job execution rows in the job_executions table.
METRICS_RETENTION_DAYS=30

# Log format: leave blank for human-readable, set to "json" for production.
LOG_FORMAT=

# ---------------------------------------------------------------------------
# Uvicorn (proxy headers)
# ---------------------------------------------------------------------------
# Comma-separated list of IPs to trust with X-Forwarded-* headers.  Set to "*"
# only behind a trusted reverse proxy (e.g. the nginx component on App Platform).
FORWARDED_ALLOW_IPS=*
