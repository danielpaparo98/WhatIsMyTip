# Database
DATABASE_URL=sqlite+aiosqlite:///./whatismytip.db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,https://whatismytip.com

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Squiggle API
SQUIGGLE_API_BASE=https://api.squiggle.com.au
SQUIGGLE_CONTACT_EMAIL=

# OpenRouter (for explanation generation)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=gptoss-120b

# Umami Analytics
UMAMI_WEBSITE_ID=your_umami_website_id_here
UMAMI_HOST=https://analytics.example.com

# Environment
ENVIRONMENT=development
ADMIN_API_KEY=your-admin-api-key-here

# Cron Job Configuration
CRON_ENABLED=true
CRON_TIMEZONE=Australia/Perth

# Daily Game Sync
CRON_DAILY_SYNC="0 2 * * *"
DAILY_SYNC_TIMEOUT_SECONDS=3600

# Match Completion Detector
CRON_MATCH_COMPLETION_CHECK="*/15 * * * *"
MATCH_COMPLETION_BUFFER_MINUTES=60
MATCH_COMPLETION_CHECK_ENABLED=True
COMPLETION_CHECK_TIMEOUT_SECONDS=300

# Tip Generation
CRON_TIP_GENERATION="0 3 * * *"
TIP_GENERATION_TIMEOUT_SECONDS=1800
TIP_GENERATION_ENABLED=True
TIP_GENERATION_REGENERATE_EXISTING=False

# Historical Data Refresh
CRON_HISTORICAL_REFRESH="0 4 * * 0"
HISTORIC_REFRESH_ENABLED=True
HISTORIC_REFRESH_SEASONS="2010-2025"
HISTORIC_REFRESH_REGENERATE_TIPS=False
HISTORICAL_REFRESH_START_YEAR=2010
HISTORICAL_REFRESH_TIMEOUT_SECONDS=7200

# Job Settings
JOB_TIMEOUT_SECONDS=3600
JOB_LOCK_EXPIRE_SECONDS=7200
JOB_MAX_RETRIES=3
JOB_RETRY_DELAY_SECONDS=60

# Alerting Configuration
ALERT_ENABLED=false
ALERT_WEBHOOK_URL=
ALERT_EMAIL_RECIPIENTS=

# Monitoring Configuration
METRICS_ENABLED=true
METRICS_RETENTION_DAYS=30
