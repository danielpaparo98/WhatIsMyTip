# ──────────────────────────────────────────────────────────────────────
# WhatIsMyTip backend env vars (template).
#
# Copy to .env for local dev: `cp .env.example .env`.  .env is
# gitignored; this template is the canonical inventory of every env
# var the FastAPI process reads, with a sensible default where safe.
#
# In production, these vars are configured on the App Platform
# service spec (via the App Platform UI or `doctl apps update
# --env ...`), not via this file.
# ──────────────────────────────────────────────────────────────────────

# ── Database & cache ────────────────────────────────────────────────
# Production: postgresql+asyncpg://<user>:<pw>@<host>:25060/<db>?ssl=require
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/whatismytip
REDIS_URL=redis://localhost:6379/0
# Verify the Postgres server's TLS certificate against the system trust
# store.  Leave at "true" in production.  Set to "false" ONLY for local
# dev against a container with a self-signed cert (no real CA chain).
DB_SSL_VERIFY=true

# ── External APIs ───────────────────────────────────────────────────
SQUIGGLE_API_BASE=https://api.squiggle.com.au
# Required by Squiggle's fair-use policy — your contact email.
SQUIGGLE_CONTACT_EMAIL=
# OpenRouter (LLM for tip explanations).  Leave blank to disable.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Admin auth ──────────────────────────────────────────────────────
# Shared secret for /api/admin/** endpoints.  Required for the
# workflow_dispatch cron trigger and any admin curl sweep.
ADMIN_API_KEY=

# ── Environment & CORS ──────────────────────────────────────────────
# development | staging | production
ENVIRONMENT=development
# Comma-separated list of allowed Origins for CORS.  In production,
# this MUST be the public site URL only (no localhost).
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Logging ─────────────────────────────────────────────────────────
# plain | json   (json in prod for log drain parsing)
LOG_FORMAT=plain

# ── Trusted upstream proxies ────────────────────────────────────────────
# FORWARDED_ALLOW_IPS restricts which upstream IPs uvicorn will trust
# for X-Forwarded-* headers (the value is consumed by the
# --forwarded-allow-ips flag in backend/Dockerfile).  App Platform's
# edge lives inside 10.0.0.0/8, which is the safe default.  Override
# ONLY if the deployment topology changes.  NEVER set to '*' /
# 0.0.0.0/0 in production — that lets any client forge the source IP
# and bypass the per-IP rate limiter.
FORWARDED_ALLOW_IPS=10.0.0.0/8

# ── Rate limiting ───────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
# Request body limit in bytes.  No upstream proxy is in front of the
# api in production, so this is the only body-size cap.  Default 5 MiB.
MAX_REQUEST_BODY_BYTES=5242880

# ── Cron / scheduler ────────────────────────────────────────────────
# Set to "false" in local dev so APScheduler doesn't fire background
# jobs every 15 minutes.  Required to be "true" in production.
CRON_ENABLED=false
CRON_TIMEZONE=Australia/Perth
CURRENT_SEASON=2026

# Crontab expressions (interpreted in CRON_TIMEZONE)
CRON_DAILY_SYNC=*/15 * * * *
DAILY_SYNC_TIMEOUT_SECONDS=3600
DAILY_SYNC_ENABLED=true

CRON_MATCH_COMPLETION_CHECK=5,20,35,50 * * * *
MATCH_COMPLETION_BUFFER_MINUTES=60
MATCH_COMPLETION_CHECK_ENABLED=true
COMPLETION_CHECK_TIMEOUT_SECONDS=300

CRON_TIP_GENERATION=0 3 * * *
TIP_GENERATION_TIMEOUT_SECONDS=1800
TIP_GENERATION_ENABLED=true
TIP_GENERATION_REGENERATE_EXISTING=false

CRON_HISTORICAL_REFRESH=0 4 * * 0
HISTORIC_REFRESH_ENABLED=true
HISTORIC_REFRESH_SEASONS=2010-2025
HISTORIC_REFRESH_REGENERATE_TIPS=false
HISTORICAL_REFRESH_START_YEAR=2010
HISTORICAL_REFRESH_TIMEOUT_SECONDS=900

# Weekly weighted-tip scikit-learn retrain.  Refits the LinearRegression
# against historical model_predictions x completed-game scores and promotes
# a new active model_version.  Cron expression is in CRON_TIMEZONE.
MODEL_RETRAIN_ENABLED=true
MODEL_RETRAIN_CRON=0 5 * * 1

# ── Job runtime ─────────────────────────────────────────────────────
JOB_TIMEOUT_SECONDS=3600
JOB_LOCK_EXPIRE_SECONDS=900
JOB_MAX_RETRIES=3
JOB_RETRY_DELAY_SECONDS=60

# ── Alerting ────────────────────────────────────────────────────────
ALERT_ENABLED=false
ALERT_WEBHOOK_URL=
ALERT_EMAIL_RECIPIENTS=
ALERT_TIMEOUT_SECONDS=10

# ── Metrics ─────────────────────────────────────────────────────────
METRICS_ENABLED=true
METRICS_RETENTION_DAYS=30
